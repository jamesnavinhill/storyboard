{
  "name": "storyboard-ai-music-video-storyboarder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "build:all": "npm run build:web",
    "ci:build": "vite build",
    "ci:check-bundle": "node scripts/check-bundle-sizes.mjs",
    "analyze": "cross-env ANALYZE=true vite build && echo Open dist/stats.html",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "dev:server": "tsx watch server/index.ts",
    "start:server": "tsx server/index.ts",
    "migrate": "tsx server/scripts/migrate.ts",
    "seed": "tsx server/scripts/seed.ts",
    "check:db": "tsx server/scripts/checkDb.ts",
    "maintain": "tsx server/scripts/maintenance.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest run src/features",
    "test:api": "vitest run server",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.24.0",
    "@tiptap/extension-code-block-lowlight": "^3.8.0",
    "@tiptap/react": "^3.8.0",
    "@tiptap/starter-kit": "^3.8.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "pino": "^9.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.4",
    "zod": "^3.24.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^6.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jszip": "^3.4.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^2.0.16",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "baseline-browser-mapping": "^2.9.11",
    "cross-env": "^7.0.3",
    "jsdom": "^27.0.0",
    "madge": "^8.0.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
